<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<!--
ZKM同款分辨率
-->

<AnchorPane prefHeight="305"
            prefWidth="430"
            minHeight="305"
            minWidth="430"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="cn.a114.klassmaster.gui.impl.AboutScreen"
>

    <style>
        .button {
        -fx-background-color: linear-gradient(#f2f2f2, #d6d6d6);
        -fx-border-color: #a7a7a7;
        -fx-border-width: 1px;
        -fx-border-radius: 3px;
        -fx-padding: 5px 15px;
        -fx-font-size: 13px;
        -fx-text-fill: #333333;
        -fx-effect: dropshadow( three-pass-box , rgba(0,0,0,0.2) , 3, 0.0 , 0 , 1 );
        }
    </style>
    <VBox alignment="TOP_CENTER" spacing="15" AnchorPane.bottomAnchor="10" AnchorPane.leftAnchor="10"
          AnchorPane.rightAnchor="10" AnchorPane.topAnchor="10">
        <!--ChatGPT moment-->
        <Label style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-effect: dropshadow( gaussian , gray , 4 , 0.5 , 1 , 1 );"
               text="a114 KlassMaster" textFill="blue"/>

        <!-- Version -->
        <VBox alignment="CENTER" spacing="5">
            <Text fx:id="version"/>
            <Label text="Copyright 2025 a114mc All rights reserved" textAlignment="CENTER" wrapText="true"/>
            <Hyperlink text="https://github.com/a114mc"/>
        </VBox>

        <Region VBox.vgrow="ALWAYS"/>

        <VBox alignment="CENTER" BorderPane.alignment="CENTER">
            <HBox alignment="CENTER" spacing="10.0">
                <!-- Buttons -->
                <Button onAction="#handler$copy" prefWidth="100" text="Copy">
                    <cursor>
                        <Cursor fx:constant="HAND"/>
                    </cursor>
                </Button>

                <!--
                    Placeholder was an invisible button
                -->
                <Button focusTraversable="false" mouseTransparent="true" opacity="0" prefWidth="100" visible="false"/>

                <Button onAction="#handler$close" prefWidth="100" text="Close">
                    <cursor>
                        <Cursor fx:constant="HAND"/>
                    </cursor>
                </Button>
            </HBox>
        </VBox>
    </VBox>
</AnchorPane>
